{
  "name": "@kanban/preload",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --external electron --external @kanban/shared && tsc -p tsconfig.json --noEmit",
    "dev": "tsup src/index.ts --format cjs --watch --external electron --external @kanban/shared",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@kanban/shared": "workspace:*"
  }
}
